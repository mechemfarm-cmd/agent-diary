{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "agent-diary",
  "version": "0.1.0",
  "identifier": "com.mechem.agent-diary",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Diary",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "wix": {}
    }
  }
}